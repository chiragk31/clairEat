# ──────────────────────────────────────────────────────────
# ClairEat Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ──────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────
APP_NAME=ClairEat
DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret-key
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://claireat.com

# ── Supabase (required) ───────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── AI Providers (at least one required) ──────────────────
# Google AI Studio — free tier: https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Groq Console — free tier: https://console.groq.com
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# ── Food APIs (optional but recommended) ──────────────────
# USDA FoodData Central — instant free key: https://api.nal.usda.gov/
USDA_API_KEY=your-usda-api-key

# Nutritionix — free dev account: https://developer.nutritionix.com
NUTRITIONIX_APP_ID=your-nutritionix-app-id
NUTRITIONIX_APP_KEY=your-nutritionix-app-key

# Edamam — free tier 1k req/month: https://developer.edamam.com
EDAMAM_APP_ID=your-edamam-app-id
EDAMAM_APP_KEY=your-edamam-app-key

# Spoonacular — 150 req/day free: https://spoonacular.com/food-api
SPOONACULAR_API_KEY=your-spoonacular-api-key

# ── Open APIs (no key needed, pre-configured) ─────────────
OPEN_FOOD_FACTS_BASE=https://world.openfoodfacts.org
THEMEALDB_BASE=https://www.themealdb.com/api/json/v1/1
OPEN_METEO_BASE=https://api.open-meteo.com/v1
WGER_BASE=https://wger.de/api/v2

# ── Rate Limiting ─────────────────────────────────────────
AI_CHAT_RATE_LIMIT=20       # requests per user per hour
MEAL_PLAN_RATE_LIMIT=5      # requests per user per day
FOOD_SEARCH_RATE_LIMIT=60   # requests per user per minute

# ── Caching ───────────────────────────────────────────────
FOOD_CACHE_MAX_SIZE=5000
FOOD_CACHE_TTL=86400        # 24 hours
AI_CACHE_MAX_SIZE=1000
AI_CACHE_TTL=3600           # 1 hour
EXTERNAL_CACHE_MAX_SIZE=500
EXTERNAL_CACHE_TTL=21600    # 6 hours

# ── Circuit Breaker ───────────────────────────────────────
AI_FAILURE_THRESHOLD=3
AI_FAILURE_WINDOW_SECONDS=60
AI_CIRCUIT_OPEN_MINUTES=2

# ── File Uploads ──────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=5
